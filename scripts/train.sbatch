#!/bin/bash
#SBATCH --job-name=Lab6
#SBATCH --output=slurm_logs/train-%j.out
#SBATCH --error=slurm_logs/train-%j.err
#SBATCH --time=00:20:00
#SBATCH --cpus-per-task=2
#SBATCH --gpus=1
#SBATCH --mem=8G
#SBATCH --partition=gpu
#SBATCH --account=dsci410_510


cd / ##Chage this to your folder
source venv/bin/activate

python scripts/train_model.py --config configs/default.yaml

RESULTS_DIR=/gpfs/projects/dsci410_510/Lab6/results
mkdir -p "$RESULTS_DIR"

ACCURACY=$(grep '^final_val_accuracy=' outputs/train_metrics.txt | cut -d '=' -f 2)
RESULTS_FILE="$RESULTS_DIR/${USER}.txt"

{
    echo "username=${USER}"
    echo "accuracy=${ACCURACY}"
    echo "metrics_file=${SLURM_SUBMIT_DIR}/outputs/train_debug_metrics.txt"
    echo "model_file=${SLURM_SUBMIT_DIR}/outputs/debug_model.pt"
    echo "slurm_job_id=${SLURM_JOB_ID}"
} > "$RESULTS_FILE"

echo "RESULTS_FILE=${RESULTS_FILE}"
